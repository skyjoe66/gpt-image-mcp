# Your OpenAI API key — https://platform.openai.com/api-keys
# NOTE: gpt-image-2 may require Organization Verification on your OpenAI org,
# otherwise calls return HTTP 403. Verify under Settings > Organization.
OPENAI_API_KEY=sk-proj-...

# Optional: absolute path where generated images are saved.
# Strongly recommended for Claude Desktop, whose working directory is
# unpredictable. In Claude Code, leave unset to save into the current project's
# ./generated-images folder.
# IMAGE_OUTPUT_DIR=/Users/joe/gpt-image-output

# Optional: override the OpenAI endpoint (rarely needed).
# OPENAI_BASE_URL=https://api.openai.com/v1
